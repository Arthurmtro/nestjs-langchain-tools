{
  "name": "nestjs-langchain-tools",
  "version": "0.3.0",
  "description": "NestJS × LangChain — LangGraph-first agents, class-validator tools, Observable streaming, auto-wired observability (LangSmith + cost), shipped adapters for Redis / Mongo / Qdrant / pgvector / Pinecone",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "default": "./dist/health/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "default": "./dist/graph/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "default": "./dist/http/index.js"
    },
    "./redis": {
      "types": "./dist/adapters/redis/index.d.ts",
      "default": "./dist/adapters/redis/index.js"
    },
    "./mongo": {
      "types": "./dist/adapters/mongo/index.d.ts",
      "default": "./dist/adapters/mongo/index.js"
    },
    "./qdrant": {
      "types": "./dist/adapters/qdrant/index.d.ts",
      "default": "./dist/adapters/qdrant/index.js"
    },
    "./pgvector": {
      "types": "./dist/adapters/pgvector/index.d.ts",
      "default": "./dist/adapters/pgvector/index.js"
    },
    "./pinecone": {
      "types": "./dist/adapters/pinecone/index.d.ts",
      "default": "./dist/adapters/pinecone/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc -p tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest \"src/.*\\.spec\\.ts$\" --testPathIgnorePatterns=\"test/integration\"",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:integration": "jest test/integration --detectOpenHandles",
    "example": "sh scripts/run-example.sh",
    "example:build": "npm run build && npm run example",
    "prepublishOnly": "npm run build",
    "version:bump": "node scripts/version-and-publish.js",
    "ci:publish": "pnpm publish --no-git-checks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arthurmtro/nestjs-langchain-tools.git"
  },
  "bugs": {
    "url": "https://github.com/arthurmtro/nestjs-langchain-tools/issues"
  },
  "homepage": "https://github.com/arthurmtro/nestjs-langchain-tools#readme",
  "keywords": [
    "nestjs",
    "langchain",
    "langgraph",
    "ai",
    "agents",
    "llm",
    "tools",
    "openai",
    "anthropic",
    "chatgpt",
    "claude",
    "gpt",
    "mistral",
    "api",
    "multi-agent",
    "rag",
    "class-validator"
  ],
  "author": "Arthur Monteiro",
  "license": "MIT",
  "peerDependencies": {
    "@langchain/anthropic": "^1.0.0",
    "@langchain/community": "^1.0.0",
    "@langchain/core": "^1.0.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/mistralai": "^1.0.0",
    "@langchain/ollama": "^1.0.0",
    "@langchain/openai": "^1.0.0",
    "@langchain/textsplitters": "^1.0.0",
    "@nestjs/common": "^11.0.12",
    "@nestjs/core": "^11.0.12",
    "@nestjs/terminus": "^11.0.0",
    "@pinecone-database/pinecone": "^6.0.0",
    "@qdrant/js-client-rest": "^1.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.0",
    "ioredis": "^5.0.0",
    "langchain": "^1.0.0",
    "mongodb": "^6.0.0",
    "pg": "^8.0.0",
    "redis": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/anthropic": {
      "optional": true
    },
    "@langchain/community": {
      "optional": true
    },
    "@langchain/langgraph": {
      "optional": true
    },
    "@langchain/mistralai": {
      "optional": true
    },
    "@langchain/ollama": {
      "optional": true
    },
    "@nestjs/terminus": {
      "optional": true
    },
    "@pinecone-database/pinecone": {
      "optional": true
    },
    "@qdrant/js-client-rest": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "mongodb": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/mistralai": "^1.0.7",
    "@langchain/ollama": "^1.2.6",
    "@langchain/openai": "^1.4.4",
    "@langchain/textsplitters": "^1.0.1",
    "@nestjs/platform-express": "^11.0.12",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/testing": "^11.0.12",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.14",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.4.7",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "langchain": "^1.3.3",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^7.12.0",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core"
    ],
    "overrides": {
      "@mistralai/mistralai": "^2.2.0"
    }
  }
}
